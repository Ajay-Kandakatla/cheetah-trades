# Finnhub — free tier includes real-time US equity trades via WebSocket.
# Sign up at https://finnhub.io/register
FINNHUB_API_KEY=d7j4kb1r01qp3g1rpc1gd7j4kb1r01qp3g1rpc20

# Default watchlist (comma-separated)
DEFAULT_SYMBOLS=NVDA,META,AAPL,MSFT,TSLA,AMD,PLTR,CRDO,AVGO,LLY

# REST poll interval (seconds) for context (open/high/low/prev close)
POLL_INTERVAL_SEC=5

# Number of ticks kept per symbol for rolling RSI/VWAP and sparkline
TICK_WINDOW=64

# Massive (formerly Polygon) — daily price aggregates for SEPA scans
MASSIVE_API_KEY=
PRICE_PROVIDER=massive

# MongoDB — overridden by docker-compose to point at the mongo service
MONGO_URL=mongodb://localhost:27017
MONGO_DB=cheetah

# Twilio WhatsApp — leave blank to disable WhatsApp alerts.
# Sandbox: send "join <your-code>" from your phone first.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=whatsapp:+14155238886
TWILIO_TO=whatsapp:+1XXXXXXXXXX
